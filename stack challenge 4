#include <stdio.h>
#include <string.h>

#define MAX 1000

int main() {
    int N1, N2;
    scanf("%d %d", &N1, &N2);

    int stack1[MAX], stack2[MAX];
    int top1 = -1, top2 = -1;

    int Q;
    scanf("%d", &Q);

    while (Q--) {
        char operation[10];
        int S, X;

        scanf("%s", operation);

        if (strcmp(operation, "PUSH") == 0) {
            scanf("%d %d", &S, &X);

            if (S == 1) {
                if (top1 == N1 - 1) {
                    printf("Overflow\n");
                } else {
                    stack1[++top1] = X;
                }
            } else if (S == 2) {
                if (top2 == N2 - 1) {
                    printf("Overflow\n");
                } else {
                    stack2[++top2] = X;
                }
            }
        }

        else if (strcmp(operation, "POP") == 0) {
            scanf("%d", &S);

            if (S == 1) {
                if (top1 == -1) {
                    printf("Underflow\n");
                } else {
                    printf("%d\n", stack1[top1--]);
                }
            } else if (S == 2) {
                if (top2 == -1) {
                    printf("Underflow\n");
                } else {
                    printf("%d\n", stack2[top2--]);
                }
            }
        }

        else if (strcmp(operation, "PEEK") == 0) {
            scanf("%d", &S);

            if (S == 1) {
                if (top1 == -1) {
                    printf("Underflow\n");
                } else {
                    printf("%d\n", stack1[top1]);
                }
            } else if (S == 2) {
                if (top2 == -1) {
                    printf("Underflow\n");
                } else {
                    printf("%d\n", stack2[top2]);
                }
            }
        }

        else if (strcmp(operation, "DISPLAY") == 0) {
            scanf("%d", &S);

            if (S == 1) {
                if (top1 == -1) {
                    printf("Empty\n");
                } else {
                    for (int i = top1; i >= 0; i--) {
                        printf("%d ", stack1[i]);
                    }
                    printf("\n");
                }
            } else if (S == 2) {
                if (top2 == -1) {
                    printf("Empty\n");
                } else {
                    for (int i = top2; i >= 0; i--) {
                        printf("%d ", stack2[i]);
                    }
                    printf("\n");
                }
            }
        }
    }

    return 0;
}
